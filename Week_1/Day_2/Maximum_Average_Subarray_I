// problem Name : Maximum Average Subarray I
// problem link : https://leetcode.com/problems/maximum-average-subarray-i/

class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double bestSum = 0;

        for (int i = 0; i <= nums.size() - k; i++) {
            double sum = 0;

            for (int j = i; j < i + k; j++) {
                sum += nums[j];
            }

            if (i == 0 || sum > bestSum) {
                bestSum = sum;
            }
        }

        return bestSum / k;
    }
};
